{
  "schemaVersion": 1,
  "id": "pathweaver",
  "version": "${version}",
  "name": "PathWeaver",
  "description": "Async mob pathfinding: only the A* search runs off the server thread, on a read-only region with a freshly-isolated finder and a per-thread path-type cache, so no shared mutable state is written off-thread. No async ticking, no async collision. Coordinates with Lithium.",
  "authors": ["Zimdin"],
  "contact": {
    "homepage": "https://modrinth.com/mod/pathweaver",
    "sources": "https://github.com/Zimdin12/PathWeaver",
    "issues": "https://github.com/Zimdin12/PathWeaver/issues"
  },
  "license": "MIT",
  "icon": "assets/pathweaver/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.pathweaver.PathWeaver"]
  },
  "mixins": ["pathweaver.mixins.json"],
  "depends": {
    "minecraft": ">=26.1 <26.2",
    "java": ">=25",
    "fabricloader": ">=0.19",
    "fabric-api": "*",
    "cloth-config": ">=26.1"
  },
  "suggests": {
    "lithium": "*",
    "modmenu": "*"
  }
}
