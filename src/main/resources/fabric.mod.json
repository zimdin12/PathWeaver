{
  "schemaVersion": 1,
  "id": "pathweaver",
  "version": "${version}",
  "name": "PathWeaver",
  "description": "Experimental opt-in A* offload for eligible Walk/Swim mobs. Default-off while immutable inputs, lifecycle safety, and fail-closed compatibility detection are reworked.",
  "authors": ["Zimdin"],
  "contact": {
    "homepage": "https://modrinth.com/mod/pathweaver",
    "sources": "https://github.com/Zimdin12/PathWeaver",
    "issues": "https://github.com/Zimdin12/PathWeaver/issues"
  },
  "license": "MIT",
  "icon": "assets/pathweaver/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.pathweaver.PathWeaver"]
  },
  "mixins": ["pathweaver.mixins.json"],
  "depends": {
    "minecraft": ">=26.1 <26.2",
    "java": ">=25",
    "fabricloader": ">=0.19",
    "fabric-api": "*",
    "cloth-config": ">=26.1"
  },
  "suggests": {
    "lithium": "*",
    "modmenu": "*"
  }
}
